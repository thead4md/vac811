# SPA rewrite for BrowserRouter — deployed under vac811.hu/beta
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /beta/

  # Curate app lives at admin/kuracio but is a React route, not a static file
  RewriteRule ^admin/kuracio$ /beta/index.html [L]

  # Don't rewrite real files or directories (assets, content JSON, admin, images)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → index.html so deep links like /beta/naptar resolve
  RewriteRule . /beta/index.html [L]
</IfModule>

# Baseline security headers
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Instagram sync (scripts/sync-instagram-feed.mjs, public/content/instagram.json)
  # serves post images directly from Meta's CDN (cdninstagram.com/fbcdn.net) — no
  # script/connect allowances needed since fetching happens server-side in CI, not
  # in the browser. media-src is set explicitly so Instagram video posts don't
  # fall back to default-src 'self'.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://accounts.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://lh3.googleusercontent.com https://img.vac811.hu https://*.cdninstagram.com https://*.fbcdn.net; media-src 'self' https://*.cdninstagram.com https://*.fbcdn.net; font-src 'self'; connect-src 'self' https://accounts.google.com https://api.github.com https://*.workers.dev; frame-src https://accounts.google.com; frame-ancestors 'self'"

  <FilesMatch "^(index\.html)$">
    Header always set X-Frame-Options "SAMEORIGIN"
  </FilesMatch>
</IfModule>

# Long-cache hashed assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
</IfModule>
